# Copy to .env on the deployment host. Do not commit real values.

# WhatsApp/insp-bot log source
ENGINEER_LOG_DIR=/path/to/insp-bot/logs/<whatsapp-group-id>@g.us
ENGINEER_TARGET_GROUP=<whatsapp-group-id>@g.us

# Local WhatsApp send/react API
ENGINEER_SEND_URL=http://127.0.0.1:3081/send
ENGINEER_REACT_URL=http://127.0.0.1:3081/react
# SEND_API_SECRET=optional-send-api-secret

# Local state files
ENGINEER_STATE_FILE=.state/engineer-info-structured-hook-state.json
ENGINEER_IMPORT_STATE_FILE=.state/feishu-import-state.json
ENGINEER_POLICY_FILE=.state/import-policy.json

# Feishu Bitable credentials
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxx
FEISHU_BITABLE_APP_TOKEN=xxxxxxxxxxxxx
FEISHU_BITABLE_TABLE_ID=tblxxxxxxxxxxxxx

# LLM API
LLM_API_BASE_URL=https://example.com/v1/chat/completions
LLM_API_KEY=sk-REPLACE_ME
LLM_MODEL=gpt-5.4
LLM_STREAM=true
LLM_MODE=review
